#!/bin/bash

set -euo pipefail

source "$(dirname "$0")/../load-host-env.sh"

mkdir -p "$STATE_DIR"

case "$(uname -s)" in
  Darwin) LIMA_YAML="$TOOLKIT_DIR/lima.macos.yaml" ;;
  Linux)  LIMA_YAML="$TOOLKIT_DIR/lima.linux.yaml" ;;
  *)      echo "error: unsupported host OS: $(uname -s)" >&2; exit 1 ;;
esac

SENTINEL_ID="$(date -u +"%Y-%m-%dT%H:%M:%SZ")-$(head -c20 /dev/random | base64)"
SENTINEL="$STATE_DIR/.provisioned"

echo "Starting lima instance \"$LIMA_INSTANCE\""
echo ""

limactl start \
  --tty=false \
  --progress \
  --name "$LIMA_INSTANCE" \
  --set ".param.sentinelId = \"$SENTINEL_ID\"" \
  --set ".param.projectDir = \"$PROJECT_DIR\"" \
  --set ".param.stateDir = \"$STATE_DIR\"" \
  "$LIMA_YAML"

if [[ "$(cat "$SENTINEL")" != "$SENTINEL_ID" ]]; then
  echo ""
  echo "Failed to provision the Lima instance."
  echo ""
  exit 1
fi
